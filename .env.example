# pagespring has no secrets — fetching is stdlib urllib against public docs.
# Settings below are optional overrides of pagespring.config.PagespringConfig
# (env vars win over the defaults). Copy to .env to use.

# Where the deliverable lands (default: incoming, relative to the project root).
# INCOMING_DIR=incoming

# Structured-logging level for the run (pf-core; default INFO).
# LOG_LEVEL=INFO

# User-Agent for all fetches. Default identifies pagespring + its repo URL;
# override for a source that mishandles the tool UA.
# PAGESPRING_UA=pagespring/x.y (+https://github.com/phierceweb/pagespring)
