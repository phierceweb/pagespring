#!/usr/bin/env bash
# Lint gate (same as CI): ruff check + ruff format check over src + tests, mypy
# strict over src/, and pf-core's structural build gate (file-size).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
[ -d .venv ] || { echo "No .venv found. Run bin/setup first." >&2; exit 1; }
.venv/bin/python -m ruff check src tests
.venv/bin/python -m ruff format --check src tests
.venv/bin/python -m mypy src
.venv/bin/python -m pf_core.guards --root src/pagespring
